---
// import Favicon from '../assets/Favicon.astro';

const { title, description } = Astro.props;
---

<link
	rel='sitemap'
	href='/sitemap-index.xml'
/>
<!-- CSS Styles -->
<link
	rel='stylesheet'
	href='/styles/css/global.css'
/>
<link
	rel='stylesheet'
	href='/styles/css/responsive.css'
/>
<slot name='style' />

<title>{title}</title>
<meta
	name='description'
	content={description}
/>

<!-- Web analytics -->
<script
	data-goatcounter='https://my-account.goatcounter.com/count'
	async
	src='//gc.zgo.at/count.js'
></script>

<!-- Open Graph tags -->
<meta
	property='og:title'
	content='Impact Web Studio'
/>
<meta
	property='og:type'
	content='website'
/>
<meta
	property='og:url'
	content='http://www.impactwebstudio.ca'
/>
<meta
	property='og:description'
	content='Impact Web Studio, Web Design and Development Services in Canada and the United States.'
/>
<meta
	property='og:image'
	content='/assets/images/iws-favicon.png'
/>
<meta
	property='og:image:alt'
	content='Impact Web Studio Favicon'
/>
<meta name="viewport" content="width=device-width, initial-scale=1">

<slot />
<!-- <Favicon /> -->
