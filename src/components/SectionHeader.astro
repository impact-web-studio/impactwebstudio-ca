---
const { topper, heading, description, alignment } = Astro.props;
---

<div class={alignment ? 'iws-container sbs' : 'iws-container'}>
	<div class='iws-content'>
		{topper && <span class='iws-topper'>{topper}</span>}
		<h2 class='iws-header'>{heading}</h2>
	</div>
	{description && <p class='iws-text'>{description}</p>}
</div>

<style>
	.iws-container{
		margin-bottom: clamp(3rem, 2.4286rem + 2.8571vw, 5rem);
	}

	.iws-container,
	.iws-content {
		display: flex;
		flex-direction: column;
		text-align: center;
		align-items:center;
	}

	.sbs{
		flex-direction: row;
		justify-content: space-between;
	}

	span {
		font-size: 0.875rem;
		color: var(--dark-three);
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	h2 {
		text-transform: uppercase;
		font-size: 1.75rem;
		line-height: 2rem;
		color: var(--dark-one);
	}

	p {
		font-size: 1rem;
		color: var(--dark-two);
	}
	/* Tablet */
@media only screen and (min-width: 600px){

	.iws-container{
		/* gap: 1rem; */
	}

	.iws-topper{
		font-size: 1rem;
	}

	.iws-header{
		font-size: 3.5rem;
		line-height: 1em;
	}

	.iws-text{
		max-width: 85%;
	}
}

	/* Desktop */
	@media screen and (min-width: 1000px) {
	}
</style>
