---

---

<section id='hero'>
	<div class='iws-container'>
		<div class='iws-flex-group'>
			<span class='iws-topper'>Impact Web Studio</span>
			<h1 class='iws-title'>Where design meets functionality</h1>
			<p class='iws-text'>
				Tincidunt lobortis feugiat vivamus at augue eget arcu dictum varius.
				Nibh tortor id aliquet lectus proin nibh condimentum.
			</p>
			<a
				href='/about'
				class='iws-button-solid'
				>Explore More</a
			>
			<a
				href='/contact'
				class='iws-button-transparent'
			>
				<img
					class='iws-img'
					loading='lazy'
					decoding='async'
					src='https://csimg.nyc3.digitaloceanspaces.com/Hero/play.svg'
					alt='play icon'
					width='17'
					height='17'
				/>
				Get in Touch
			</a>
		</div>
	</div>
</section>

<style>
	/*-- -------------------------- -->
	<---           Hero             -->
	<--- -------------------------- -*/
	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#hero {
			overflow: hidden;
			position: relative;
			z-index: 10;
			display: flex;
			flex-direction: column;
			padding: 4rem 0.75rem 2rem 0.75rem;
			background-color: var(--dark-one);
		}
		.iws-container {
			width: 100%;
			max-width: 80rem;
			height: 100%;
			margin: auto;
			position: relative;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			gap: 5.5rem;
			/* background-color: var(--bgColor); */
		}
		.iws-content {
			/* set text align to left if content needs to be left aligned */
			text-align: left;
			width: 100%;
			max-width: 39.375rem;
			display: flex;
			flex-direction: column;
			/* centers content horizontally, set to flex-start to left align */
			align-items: flex-start;
			position: relative;
			z-index: 10;
		}

		.iws-topper {
			font-size: 0.875rem;
			color: var(--accent-yellow-light-mode);
			text-align: center;
			letter-spacing: 0.1em;
			line-height: 1rem;
		}
		.iws-title {
			font-size: 1.75rem;
			font-weight: 900;
			text-transform: uppercase;
			line-height: 1.15em;
			width: 100%;
			/* max-width: 17ch; */
			color: var(--white-one);
		}
		.iws-text {
			/* 16px - 20px */
			font-size: clamp(1rem, 2.5vw, 1.25rem);
			line-height: 1.5em;
			width: 100%;
			max-width: 43.75rem;
			/* 28px - 40px */
			margin: 0 0 clamp(1.75rem, 4vw, 2.5rem);
			color: var(--bodyTextColorWhite);
			opacity: 0.8;
		}
		.iws-button-solid {
			font-size: 1rem;
			text-align: center;
			/* 46px - 56px */
			line-height: clamp(2.875rem, 5.5vw, 3.5rem);
			text-decoration: none;
			font-weight: 700;
			/* clips corners of the before element */
			overflow: hidden;
			margin: 0;
			color: #fff;
			padding: 0 1.75rem;
			background-color: var(--primary);
			display: inline-flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.75rem;
			position: relative;
			z-index: 1;
			transition: color 0.3s;
		}
		.iws-button-solid:before {
			content: '';
			position: absolute;
			display: block;
			height: 100%;
			width: 0%;
			background: #000;
			opacity: 1;
			top: 0;
			left: 0;
			z-index: -1;
			transition: width 0.3s;
		}
		.iws-button-solid:hover {
			color: #fff;
		}
		.iws-button-solid:hover:before {
			width: 100%;
		}
		.iws-picture {
			width: 100%;
			/* 427px - 581px */
			max-width: clamp(26.6875rem, 50vw, 36.3125rem);
			height: auto;
			display: flex;
			align-items: flex-end;
			position: relative;
			z-index: 7;
		}
		.iws-picture img {
			width: 100%;
			height: auto;
		}
		.iws-wave-background {
			width: 100%;
			height: auto;
			display: block;
			position: absolute;
			left: 0;
			bottom: -1px;
			z-index: 1;
		}
	}
	/* Tablet - 768px */
	@media only screen and (min-width: 48rem) {
		#hero {
			padding-bottom: 9.375rem;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
		}
		.iws-container {
			justify-content: flex-start;
			flex-direction: row;
		}
		.iws-content {
			text-align: left;
			width: 53%;
			align-items: flex-start;
		}
		.iws-picture {
			width: 56%;
		}
	}
	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#hero {
			padding-bottom: 17vw;
		}
		.iws-picture {
			width: 45%;
		}
	}
</style>
