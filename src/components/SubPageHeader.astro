---
const { pageTitle, pageHeader, pageDescription } = Astro.props;
---

<section class='container top subpage'>
	<div class='wrapper'>
		{pageTitle && <h1 class='iws-topper'>{pageTitle}</h1>}
		<div class='sbs'>
			{pageHeader && <h2 class='iws-title'>{pageHeader}</h2>}
			{pageDescription && <p class='iws-text'>{pageDescription}</p>}
		</div>
	</div>
</section>

<style>
	.wrapper {
		padding-top: 0px;
		padding-bottom: 0px;
	}

	.sbs {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
	}
	@media screen and (width >= 40rem) {
		.sbs {
			flex-direction: row;
			align-items: center;
		}

		h1 {
			width: 50%;
		}

		p {
			width: 45%;
		}
	}
	h1 {
		font-size: var(--topperFontSize);
		color: var(--dark-three);
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}
	h2 {
		text-transform: uppercase;
		font-size: calc(var(--headerFontSize) * 1.3);
	}
	p {
		text-align: left;
		font-size: var(--bodyFontSize);
		color: var(--dark-two);
	}
</style>
