---
import { client } from '../_data/client.js';

const email = client.email || null;
const phone = client.phone || null;
// const lineOne = client.address.lineOne || null;
// const lineTwo = client.address.lineTwo || null;
const city = client.address.city || null;
const province = client.address.province || null;
// const postalCode = client.address.postalCode || null;
const logo = client.logo.footer || null;
---

<footer id='footer'>
	<div class='container'>
		<div class='left-section'>
			{
				logo && (
					<>
						<a
							class='logo'
							href='/'
						>
							<img
								loading='lazy'
								decoding='async'
								src={logo}
								alt='logo'
							/>
						</a>
					</>
				)
			}
			<p>
				We believe small businesses deserve better. Just because you're small, doesn't mean your site needs to be. Let us make you something amazing.
			</p>
		</div>
		<div class='right-section'>
			<div class='lists'>
				<div class="navigation-links">
					<h2>Quick Links</h2>
					<ul>
						<li>
							<a href='/'>Home</a>
						</li>
						<li>
							<a href='/about'>About Us</a>
						</li>
						<li>
							<a href='/projects'>Projects</a>
						</li>
						<li>
							<a href='/reviews'>Reviews</a>
						</li>
						<li>
							<a href='/contact'>Contact</a>
						</li>
					</ul>
				</div>
				<div class="contact-info">
					<h2>Contact</h2>
					<ul>
						<li>
							<a href='/contact'>
								{city && <>{city},</>}
								{province && <>{province}.</>}
							</a>
						</li>
						{
							phone && (
								<li>
									<a href={`tel:${phone}`}>T: {phone}</a>
								</li>
							)
						}
						{
							email && (
								<li>
									<a href={`mailto:${email}`}>E: {email}</a>
								</li>
							)
						}
					</ul>
				</div>
			</div>
		</div>
	</div>

	<div class='credit'>
		<span>Designed and Hand Coded by</span>
		<a
			href='https://www.impactwebstudio.ca'
			target='_blank'
			rel='noopener'
			>Impact Web Studio</a
		>
		<span class='copyright'> | Copyright 2025 - Present</span>
	</div>
</footer>

<style>
/* Mobile */
@media only screen and (min-width: 0rem) {
	#footer {
		background: var(--dark-one);
		padding: 3rem 0.75rem;
		font-size: min(4vw, 1.2em);
	}

	.container{
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	#footer .left-section {
		margin: auto;
		text-align: left;
	}
	#footer .left-section .logo {
		display: inline-block;
		margin: auto;
		height: auto;
		text-align: left;
	}
	#footer .left-section .logo img {
		display: block;
		height: 100%;
		width: 100%;
	}
	#footer .left-section p {
		padding: 0rem 0.5rem;
		width: 100%;
		font-size: 0.875rem;
		color: var(--light-two);
	}
	#footer .right-section {
		margin: auto;
		max-width: 25.4375rem;
		width: 100%;
	}
	#footer .right-section .lists {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		justify-content: space-between;
		max-width: 19.1875rem;
		width: 100%;
	}
	#footer .right-section .lists div {
		margin-top: 0;
		margin-bottom: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	#footer .right-section .lists ul li {
		list-style: none;
		font-size: 1rem;
		color: var(--light-one);
	}
	#footer .right-section .lists ul li a {
		text-decoration: none;
		color: var(--light-one);
		transition: color 0.3s;
	}
	#footer .right-section .lists ul li a:hover {
		color: var(--accent-yellow-light-mode);
	}
	#footer .right-section .lists h2 {
		position: relative;
		text-transform: uppercase;
		font-size: 1.125rem;
		font-weight: bold;
		color: var(--light-one);
		height: fit-content;
		width: fit-content;
	}
	#footer .right-section .lists h2:before {
		position: absolute;
		bottom: -0.25rem;
		left: 0;
		content: '';
		opacity: 1;
		display: block;
		background: var(--accent-yellow-light-mode);
		height: 0.125rem;
		width: 100%;
	}
	#footer .right-section .lists ul:nth-of-type(3) {
		margin-top: 3.125rem;
	}
	#footer .right-section .lists ul:nth-of-type(3) li {
		display: flex;
		justify-content: flex-start;
		align-items: center;
		margin-bottom: 1rem;
	}
	#footer .right-section .lists ul:nth-of-type(3) li:last-of-type {
		margin-bottom: 0;
	}
	#footer .right-section .buttons {
		display: flex;
		justify-content: center;
	}
	#footer .right-section .iws-button-solid {
		margin: 0;
		height: 3.3125rem;
		width: 15.625rem;
		padding-top: 0.1875rem;
	}
	#footer .credit {
		margin: auto;
		margin-top: 6.25rem;
		width: 100%;
		font-size: 1rem;
		line-height: 2.25rem;
		color: var(--light-one);
		text-align: center;
	}
	#footer .credit a {
		text-decoration: none;
		font-size: 1rem;
		color: var(--primary);
	}
	#footer .credit a:hover {
		text-decoration: underline;
	}
	#footer .credit .copyright {
		display: block;
		font-size: 1rem;
	}
}
/* Small Desktop */
@media only screen and (min-width: 64rem) {
	#footer {
		font-size: min(1.2vw, 1em);
	}
	#footer .container {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		justify-content: space-between;
		margin: auto;
		max-width: 82.5rem;
		width: 100%;
		padding: 0;
	}
	#footer .left-section {
		margin: 0;
		width: 25.5625rem;
		text-align: left;
	}
	#footer .left-section .logo {
		margin-left: 0;
		height: 2.5rem;
		text-align: left;
	}
	#footer .left-section p {
		margin-left: 0;
		text-align: left;
	}
	#footer .right-section {
		margin: 0;
		max-width: none;
		width: 38.0625rem;
	}
	#footer .right-section .lists {
		margin: 0;
		width: 100%
	}
	#footer .right-section .lists ul li a {
		position: relative;
	}
	#footer .right-section .lists ul li a:before {
		position: absolute;
		bottom: -0.1875rem;
		left: 0;
		content: '';
		opacity: 1;
		display: block;
		background: var(--primary);
		height: 0.125rem;
		width: 0%;
		transition: width 0.3s;
	}
	#footer .right-section .lists ul li a:hover:before {
		width: 100%;
	}
	#footer .right-section .lists ul:nth-of-type(3) {
		margin-top: 0;
	}
	#footer .right-section .lists ul:nth-of-type(3) li:first-of-type {
		margin-bottom: 0;
	}
	#footer .right-section .buttons {
		justify-content: flex-start;
	}
	#footer .credit .copyright {
		display: inline-block;
	}
}
/* Dark Mode */
@media only screen and (min-width: 0rem) {
	body.dark-mode #footer {
		background: #061623;
	}
}
</style>