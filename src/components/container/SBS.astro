---
import BenefitsCard from '../home/BenefitsCard.astro';
---

<section id='sbs' class="container">
	<div class='iws-container wrapper'>
		<!-- Left Image Section -->
		<div class='iws-left'>
			<div class="iws-content">
				<span class='iws-topper'>What we offer</span>
				<h2 class='iws-header'>
					websites starting at <span class='highlight'>$0 down</span> and <span
						class='highlight'>$175 per month</span
					>
				</h2>
				<p class='iws-text'>
					We offer $0 down for a standard 5 page small business website. If you
					need more than that then we have to do custom pricing based on the scope
					of work, number of additional pages, and time involved. 12 month minimum
					contract. Includes design, development, hosting, unlimited edits, 24/7
					support, and lifetime updates.
				</p>
			</div>
			<picture class='iws-picture'>
				<source
					media='(max-width: 600px)'
					srcset='/assets/images/Website Development.webp'
				/>
				<source
					media='(min-width: 601px)'
					srcset='/assets/images/Website Development.webp'
				/>
				<img
					aria-hidden='true'
					decoding='async'
					src='/assets/images/Website Development.webp'
					alt='website development'
					loading='lazy'
					width='400'
					height='563'
					class="section-image"
				/>
			</picture>
		</div>
		<!-- Right Content Section-->
		<div class='iws-right'>
			<ul class='iws-flex-group benefit-cards'>
				<BenefitsCard
					icon='CheckIcon'
					title='100% secure'
					description='Our sites are just static HTML and CSS code, meaning there’s literally nothing that can be hacked.'
				/>
				<BenefitsCard
					icon='CheckIcon'
					title='Custom Designed'
					description='Our designs are made by an in-house design team, which allows us to make anything we want.'
				/>
				<BenefitsCard
					icon='CheckIcon'
					title='100 pagespeed score'
					description='Our sites have zero bloat, zero waste, and built with purpose so we get perfect 98-100/100 speed scores with Google.'
				/>
				<BenefitsCard
					icon='CheckIcon'
					title='money back guarantee'
					description="If we can't design something you like, you get your money back and the contract is cancelled. We stand by our work."
				/>
				<BenefitsCard
					icon='CheckIcon'
					title='Unlimited edits'
					description="Need to make an update? Just let us know and we'll get it done for you."
				/>
				<BenefitsCard
					icon='CheckIcon'
					title='SEO focused'
					description='No snake oil, no tricks, no lies. We explain very clearly what SEO is, how it works, and what we can do to get you ranking.'
				/>
			</ul>
		</div>
	</div>
</section>

<style>
		
#sbs{
	background: var(--light-one);
}
.iws-container {
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	margin: auto;
	max-width: 80rem;
	width: 100%;
	row-gap: 2.5rem;
}
.iws-left {
	position: relative;
	width: 100%;
	height: fit-content;
	display: flex;
	flex-direction: column-reverse;
	align-items: center;
	justify-content: space-between
}

@media screen and (width >= 68.75rem){
	.iws-left{
		flex-direction: row;
	}

	.iws-content > *{
		text-align: left;
	}

	.iws-content{
		max-width: 600px;
	}

}
.iws-picture {
	border-radius: 1.5em;
	overflow: hidden;
	width: 100%;
	height: 100%;
}
.iws-picture img {
	height: 100%;
	width: 100%;
	object-fit: contain;
	/* background: var(--off-white-bg); */
	border-radius: 2rem;
}

.iws-right {
	margin: auto;
}

.iws-topper,
.iws-header,
.iws-text {
	text-align: center;
}
.iws-topper {
	margin-bottom: 0.25rem;
}
.iws-header {
	text-transform: uppercase;
	color: var(--dark-one);
}

.highlight {
	color: var(--accent-blue-light-mode);
}

.iws-flex-group {
	position: relative;
	border-radius: 1rem;
	/* 16px - 32px */
	padding: clamp(1rem, 3vw, 2rem);
}

.benefit-cards {
	width: 100%;
	margin: 0 0 1.5rem 0;
	padding: 0;
	display: grid;
	grid-template-columns: 1fr;
	align-items: center;
	gap: clamp(1rem, 2vw, 1.25rem);
}

@media screen and (width >= 40rem){
	.benefit-cards{
		grid-template-columns: repeat(2, 1fr);
	}
	picture, img{
		max-width: 500px;
	}
}
.iws-flex-p {
	margin: 0 0 1rem;
	color: var(--dark-one);
}

.iws-quote-icon {
	position: absolute;
	bottom: 0rem;
	/* 16px - 32px */
	right: clamp(1rem, 4vw, 2rem);
	height: auto;
	/* 60px - 136px */
	width: clamp(3.75rem, 10vw, 8.5rem);
}
.iws-button-solid {
	margin-top: 2rem;
}

/*-- -------------------------- -->
<---       Side By Side         -->
<--- -------------------------- -*/
/* Mobile - 360px */
#sbs-r {
	padding: var(--sectionPadding);
}
#sbs-r .iws-container {
	display: flex;
	flex-direction: column;
	justify-content: center;
	align-items: center;
	margin: auto;
	max-width: 80rem;
	width: 100%;
	row-gap: 2.5rem;
}
#sbs-r .iws-left {
	position: relative;
	height: 39.75em;
	/* using ems so we can use font size to scale the whole section */
	width: 39.4375em;
	/* scaling the font size with the view width */
	font-size: min(2.31vw, 0.7em);
}
#sbs-r .iws-picture {
	position: absolute;
	display: block;
	border-radius: 1.5em;
	/* clips img tag corners */
	overflow: hidden;
}
#sbs-r .iws-picture img {
	position: absolute;
	top: 0;
	left: 0;
	height: 100%;
	width: 100%;
	/* makes image act like a background image */
	object-fit: cover;
}
#sbs-r .iws-picture {
	top: 0;
	right: 0;
	height: 36.3125em;
	width: 32.625em;
}
#sbs-r .iws-picture2 {
	bottom: 0;
	left: 0;
	/* 6px - 12px */
	border: clamp(0.375em, 1.5vw, 0.75em) solid #fff;
	background-color: #fff;
	height: 25em;
	width: 25.875em;
	box-shadow: rgba(0, 0, 0, 0.1) 0px 0px 40px;
}
#sbs-r .iws-right {
	margin: auto;
	max-width: 33.875rem;
}
#sbs-r .iws-topper {
	margin-bottom: 0.25rem;
	text-align: left;
}


#sbs-r .iws-flex-group {
	position: relative;
	border-radius: 1rem;
	/* 16px - 32px */
	padding: clamp(1rem, 3vw, 2rem);
}
#sbs-r .iws-flex-p {
	margin: 0 0 1rem;
	color: var(--dark-one);
}

#sbs-r .iws-quote-icon {
	position: absolute;
	bottom: 0rem;
	/* 16px - 32px */
	right: clamp(1rem, 4vw, 2rem);
	height: auto;
	/* 60px - 136px */
	width: clamp(3.75rem, 10vw, 8.5rem);
}

/* Desktop - 1024px */
@media only screen and (min-width: 64rem) {
	#sbs-r .iws-container {
		flex-flow: row;
		justify-content: space-between;
		gap: 3.25rem;
	}
	#sbs-r .iws-left {
		/* sends it to the right */
		order: 2;
		font-size: min(1.2vw, 1em);
		flex: none;
	}
	#sbs-r .iws-right {
		margin: 0;
	}
}

</style>