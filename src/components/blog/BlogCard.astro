---
const {image, title, date, category, href} = Astro.props;

const formatDate = (isoString: string) => {
    const date = new Date(isoString);
    return date.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric"
    }).replace(/(\d+)(?=(st|nd|rd|th))/g, "$1");
};

const formattedDate = formatDate(date);
---

<li class="iws-item">
    <a class="iws-link" href={href}>
        <picture class="iws-picture">
            <source media="(max-width: 600px)"
                srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/agency-client.png">
            <source media="(min-width: 601px)"
                srcset="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/MISC/agency-client.png">
            <img decoding="async"
                src={image}
                alt="agency" width="413" height="374" aria-hidden="true">
        </picture>
        <div class="iws-item-text">
            <h3 class="iws-h3">
                {title}
                <picture class="iws-icon-wrapper">
                    <img class="iws-icon" decoding="async"
                            src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Images/Graphics/agency-arrow-upper-right.svg"
                            alt="arrow" width="413" height="374" aria-hidden="true">
                </picture>
            </h3>
            <div class="iws-info">
                <span class="iws-date">
                    <img class="iws-date-icon" decoding="async"
                            src="/assets/svgs/calendar.svg"
                            alt="calendar" width="413" height="374" aria-hidden="true">
                    {formattedDate}
                </span>
                <span class="iws-category">
                    {category}
                </span>
            </div>
        </div>
    </a>
</li>
                                

<style>
/*-- -------------------------- -->
<---        Recent Posts        -->
<--- -------------------------- -*/
/* Mobile - 360px */
@media only screen and (min-width: 0rem) {
    .iws-item {
        list-style: none;
        display: flex;
        flex-direction: column;
        grid-column: span 12;
    }
    .iws-item:hover .iws-h3,
    .iws-item:hover .iws-date,
    .iws-item:hover .iws-category {
        color: var(--light-one);
    }
    .iws-item:hover .iws-item-text {
        background-color: var(--primary-blue);
    }
    .iws-item:hover .iws-icon-wrapper {
        border-color: var(--light-one);
    }
    .iws-item:hover .iws-icon,
    .iws-item:hover .iws-date-icon {
        filter: brightness(1000%) grayscale(1);
    }
    .iws-item:hover .iws-icon {
        transform: rotate(45deg);
    }
    .iws-item:hover .iws-category::before {
        background-color: var(--light-one);
        opacity: 0.3;
    }
    .iws-link {
        text-decoration: none;
        display: flex;
        flex-direction: column;
        /* if one card has more content then the others, the card will stretch to fill the parent container */
        flex-grow: 1;
        gap: 1rem;
    }
    .iws-picture {
        width: 100%;
        height: 20rem;
        margin: 0;
        border-radius: 1.5rem;
        display: block;
        position: relative;
        z-index: 1;
        overflow: hidden;
    }
    .iws-picture img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
    }
    .iws-item-text {
        padding: 1.25rem;
        background-color: var(--off-white-bg);
        border-radius: 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        /* makes the item text the element that grows to fill the container */
        flex-grow: 1;
        transition: background-color 0.3s;
    }
    .iws-h3 {
        /* 20px - 25px */
        font-size: clamp(1.25rem, 1.8vw, 1.5625rem);
        line-height: 1.2em;
        text-align: left;
        margin: 0;
        color: var(--dark-one);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        transition: color 0.3s;
    }
    .iws-icon-wrapper {
        width: 3rem;
        height: 3rem;
        border: 1px solid #bababa;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        /* prevents the parent flexbox from shrinking the icon */
        flex-shrink: 0;
        transition: border-color 0.3s;
    }
    .iws-icon {
        width: auto;
        height: 0.75rem;
        transition:
            filter 0.3s,
            transform 0.3s;
    }
    .iws-info {
        margin: 1rem 0 0;
        padding: 1rem 0 0;
        border-top: 1px solid #e8e8e8;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .iws-date {
        font-size: 0.875rem;
        line-height: 1.5em;
        text-align: left;
        color: var(--dark-one);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: color 0.3s;
    }
    .iws-date-icon {
        width: auto;
        height: 1.5rem;
        transition: filter 0.3s;
    }
    .iws-category {
        font-size: 0.875rem;
        /* centers the text if the category bullet has to span multiple lines */
        text-align: center;
        padding: 0.25rem 1rem;
        color: var(--light-one);
        border-radius: 5rem;
        position: relative;
        z-index: 0;
        overflow: hidden;
    }
    .iws-category::before {
        content: "";
        width: 100%;
        height: 100%;
        background: var(--dark-two);
        position: absolute;
        top: 0;
        left: 0;
        z-index: -1;
    }
    .iws-bubbles {
        width: 20.0625rem;
        height: 26.4375rem;
        display: none;
        position: absolute;
        top: 66.4375rem;
        right: -8.75rem;
        z-index: -1;
    }
    .iws-bubbles:before {
        /* white border bubble */
        content: "";
        width: 16.5rem;
        height: 16.5rem;
        background: transparent;
        opacity: 1;
        border: 1px solid var(--dark-one);
        border-radius: 50%;
        display: block;
        position: absolute;
        top: 0;
        right: 0;
        animation-name: floatAnimation;
        animation-duration: 5s;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-fill-mode: forwards;
    }
    .iws-bubbles:after {
        /* orange bubble */
        content: "";
        width: 16.5rem;
        height: 16.5rem;
        background: var(--primary-blue);
        opacity: 0.1;
        border-radius: 50%;
        display: block;
        position: absolute;
        bottom: 0;
        left: 0;
        z-index: -1;
        animation-name: floatAnimation2;
        animation-duration: 14s;
        animation-timing-function: ease-in-out;
        animation-iteration-count: infinite;
        animation-fill-mode: forwards;
    }
}
/* Tablet - 768px */
@media only screen and (min-width: 48rem) {
    .iws-bubbles {
        display: block;
    }
}
/* Desktop - 1024px */
@media only screen and (min-width: 64rem) {
    .iws-container {
        max-width: 80rem;
    }
    .iws-item {
        grid-column: span 4;
    }
    .iws-bubbles {
        top: 17.5625rem;
    }
}
/* Large Desktop - 1300px */
@media only screen and (min-width: 81.25rem) {
    .iws-bubbles {
        margin-right: -61.875rem;
        right: 50%;
    }
}

                                
</style>