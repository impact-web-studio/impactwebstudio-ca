---
const title = 'About | Impact Web Studio';
const description = 'Meta description for the page';
preloadImg: '/assets/images/cabinets2.jpg';

import Layout from 'src/layouts/Layout.astro';
import PageBanner from '@/components/PageBanner.astro';
import CTA from 'src/components/CTA.astro';
---

<Layout
	title={title}
	description={description}
>
	<link
		rel='stylesheet'
		href='/public/styles/css/about.css'
		slot='head'
	/>

	<PageBanner pageTitle='About Us' />

	<!-- ============================================ -->
	<!--                 Side By Side                 -->
	<!-- ============================================ -->

	<section id='sbs'>
		<div class='iws-container'>
			<!-- Left Image Section -->
			<div class='iws-left'>
				<picture class='iws-picture iws-picture1'>
					<source
						media='(max-width: 600px)'
						srcset='/assets/images/cabinets2-m.jpg'
					/>
					<source
						media='(min-width: 601px)'
						srcset='/assets/images/cabinets2.jpg'
					/>
					<img
						aria-hidden='true'
						decoding='async'
						src='/assets/images/cabinets2.jpg'
						alt='cabinets'
						loading='lazy'
						width='400'
						height='563'
					/>
				</picture>
				<picture class='iws-picture iws-picture2'>
					<source
						media='(max-width: 600px)'
						srcset='/assets/images/construction-m.jpg'
					/>
					<source
						media='(min-width: 601px)'
						srcset='/assets/images/construction.jpg'
					/>
					<img
						aria-hidden='true'
						decoding='async'
						src='/assets/images/construction.jpg'
						alt='house'
						loading='lazy'
						width='400'
						height='563'
					/>
				</picture>
			</div>
			<!-- Right Content Section-->
			<div class='iws-right'>
				<span class='iws-topper'>About Us</span>
				<h2 class='iws-title'>About Company Title</h2>
				<p class='iws-text'>
					In consequat tincidunt turpis sit amet imperdiet. Praesent Class
					officelan nonatoureanor mauris laoreet, iaculis libero quis. Curabitur
					et tempus eri consequat tincidunt turpis sit amet imperdiet. Praesent
					nonatourean olei aptent taciti sociosqu ad litora torquent per.
				</p>
				<p class='iws-text'>
					In consequat tincidunt turpis sit amet imperdiet. Praesent Class
					officelan nonatoureanor mauris laoreet, iaculis libero quis. Curabitur
					et tempus eri consequat tincidunt turpis sit amet imperdiet. Praesent
					nonatourean olei aptent taciti sociosqu ad litora torquent per.
				</p>
				<div class='iws-flex-group'>
					<p class='iws-flex-p'>
						In consequat tincidunt turpis sit amet imperdiet. Praesent Classei
						consequat tincidunt turpis sit amet imperdiet for mind.
					</p>
					<span class='iws-name'>Justin Time</span>
					<span class='iws-job'>CEO-Founder</span>
					<img
						class='iws-quote-icon'
						loading='lazy'
						decoding='async'
						src='https://csimg.nyc3.digitaloceanspaces.com/SideBySide/quote-white.svg'
						alt='gavel'
						width='136'
						height='77'
					/>
				</div>
				<a
					href='/projects'
					class='iws-button-solid'
					>Our Projects</a
				>
			</div>
		</div>
	</section>
	<CTA />
</Layout>

<style>
	.banner {
		position: relative;
		background: var(--primary-blue);
		text-align: center;
		color: white;
		padding: var(--bannerPadding);
		display: flex;
		flex-direction: column;
		gap: 0rem;
	}

	h1 {
		color: var(--light-one);
		font-size: calc(var(--headerFontSize) * 1.5);
		text-transform: uppercase;
		letter-spacing: 0em;
		line-height: 1em;
	}

	span {
		text-transform: uppercase;
		color: var(--accent-yellow-dark-mode);
		font-size: var(--topperFontSize);
		font-weight: 700;
		letter-spacing: clamp(0.1rem, 0.0571rem + 0.2143vw, 0.25rem);
	}
</style>
