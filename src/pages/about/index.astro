---
import Layout from 'src/layouts/Layout.astro';
import PageBanner from '@/components/PageBanner.astro';
import OurProcess from '@/components/pricing/OurProcess.astro';
import CTA from 'src/components/CTA.astro';

const title = 'About | Impact Web Studio';
const description = 'Meta description for the page';
preloadImg: '/assets/images/cabinets2.jpg';
---

<Layout
	title={title}
	description={description}
>
	<link
		rel='stylesheet'
		href='/public/styles/css/about.css'
		slot='head'
	/>

	<PageBanner pageTitle='About Us' />

	<!-- ============================================ -->
	<!--                 Side By Side                 -->
	<!-- ============================================ -->

	<section id='sbs'>
		<div class='iws-container'>
			<!-- Left Image Section -->
			<div class='iws-left'>
				<picture class='iws-picture iws-picture1'>
					<source
						media='(max-width: 600px)'
						srcset='/assets/images/toronto-cn-tower.webp'
					/>
					<source
						media='(min-width: 601px)'
						srcset='/assets/images/toronto-cn-tower.webp'
					/>
					<img
						aria-hidden='true'
						decoding='async'
						srcset='/assets/images/toronto-cn-tower.webp'
						alt='cabinets'
						loading='lazy'
						width='400'
						height='563'
					/>
				</picture>
				<picture class='iws-picture iws-picture2'>
					<source
						media='(max-width: 600px)'
						srcset='/assets/images/kenny/kenny-outdoors.jpeg'
					/>
					<source
						media='(min-width: 601px)'
						srcset='/assets/images/kenny/kenny-outdoors.jpeg'
					/>
					<img
						aria-hidden='true'
						decoding='async'
						srcset='/assets/images/kenny/kenny-outdoors.jpeg'
						alt='house'
						loading='lazy'
						width='400'
						height='563'
					/>
				</picture>
			</div>
			<!-- Right Content Section-->
			<div class='iws-right'>
				<h1 class='iws-topper'>About Impact Web Studio</h1>
				<h2 class='iws-title'>Behind the scenes</h2>
				<p class='iws-text'>
					I'm Kenny, the owner and lead developer at Impact Web Studio. My
					journey into web development started in high school with robotics, but
					I quickly gravitated toward web design and development during my
					university studies. Coming from a family of nine, I initially built
					websites to help my siblings launch their businesses. That passion
					grew into a full-time career, and now I run a team dedicated to
					creating high-quality websites for small businesses across Canada and
					the United States.
				</p>
				<p class='iws-text'>
					Over time, what we've found was that one of the biggest challenges
					small business owners face is the upfront cost of a professional
					website. Those that can afford it sometimes end up with outdated,
					poorly designed sites that don't perform well. It's a frustrating
					situation - businesses either don't have the budget for a great
					website or don't know who to trust to build one.
				</p>
				<p class='iws-text'>
					That's why I created a pricing model that works for them: $0 down and
					just $175 a month. This makes it easy for small businesses to get a
					modern, professional website without the financial strain. At Impact
					Web Studio, we're focused on making web design accessible, effective,
					and stress-free, so business owners can focus on what they do
					best-growing their business.
				</p>
				<div class='iws-flex-group'>
					<p class='iws-flex-p'>
						<i>
							Impact Web Studio was started with a simple belief: every
							entrepreneur deserves a website that works as hard as they do.
						</i>
					</p>
					<span class='iws-name'>Kenny Nguyen</span>
					<span class='iws-job'>Owner, Founder</span>
					<img
						class='iws-quote-icon'
						loading='lazy'
						decoding='async'
						src='https://csimg.nyc3.digitaloceanspaces.com/SideBySide/quote-white.svg'
						alt='gavel'
						width='136'
						height='77'
					/>
				</div>
				<a
					href='/contact'
					class='iws-button-solid'
					>Get Started</a
				>
			</div>
		</div>
	</section>
	<OurProcess />
	<CTA />
</Layout>

<style>
	.banner {
		position: relative;
		background: var(--primary-blue);
		text-align: center;
		color: white;
		padding: var(--bannerPadding);
		display: flex;
		flex-direction: column;
		gap: 0rem;
	}

	h1 {
		text-transform: uppercase;
		color: var(--accent-yellow-light-mode);
		font-size: var(--topperFontSize);
		font-weight: 700;
		letter-spacing: clamp(0.1rem, 0.0571rem + 0.2143vw, 0.25rem);
	}

	h2 {
		color: var(--dark-one);
		font-size: calc(var(--headerFontSize) * 1.5);
		text-transform: uppercase;
		letter-spacing: 0em;
		line-height: 1em;
	}

	/* Mobile - 360px */
	#sbs {
		padding: var(--sectionPadding);
	}
	#sbs .iws-container {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		margin: auto;
		max-width: 80rem;
		width: 100%;
		row-gap: 2.5rem;
	}
	#sbs .iws-left {
		position: relative;
		height: 39.75em;
		/* using ems so we can use font size to scale the whole section */
		width: 39.4375em;
		/* scaling the font size with the view width */
		font-size: min(2.31vw, 0.7em);
	}
	#sbs .iws-picture {
		position: absolute;
		display: block;
		border-radius: 1.5em;
		/* clips img tag corners */
		overflow: hidden;
	}
	#sbs .iws-picture img {
		position: absolute;
		top: 0;
		left: 0;
		height: 100%;
		width: 100%;
		/* makes image act like a background image */
		object-fit: cover;
	}
	#sbs .iws-picture1 {
		top: 0;
		left: 0;
		height: 36.3125em;
		width: 32.625em;
	}
	#sbs .iws-picture2 {
		bottom: 0;
		right: 0;
		/* 6px - 12px */
		border: clamp(0.375em, 1.5vw, 0.75em) solid #fff;
		background-color: #fff;
		height: 25em;
		width: 25.875em;
		box-shadow: rgba(0, 0, 0, 0.1) 0px 0px 40px;
	}
	#sbs .iws-right {
		margin: auto;
		max-width: 33.875rem;
	}
	#sbs .iws-topper {
		margin-bottom: 0.25rem;
		text-align: left;
	}
	#sbs .iws-title {
		max-width: 50rem;
		text-align: left;
	}
	#sbs .iws-text {
		margin-bottom: 1rem;
		max-width: 46.875rem;
		color: var(--bodyTextColor);
		text-align: left;
	}
	#sbs .iws-text:last-of-type {
		margin-bottom: 2rem;
	}
	#sbs .iws-flex-group {
		position: relative;
		border-radius: 1rem;
		background-color: #f7f7f7;
		/* 16px - 32px */
		padding: clamp(1rem, 3vw, 2rem);
	}
	#sbs .iws-flex-p {
		margin: 0 0 1rem;
		/* 14px - 16px */
		font-size: clamp(0.875rem, 1.5vw, 1rem);
		line-height: 1.5em;
		color: #353535;
	}
	#sbs .iws-name {
		display: block;
		margin: 0 0 0.25rem;
		text-transform: uppercase;
		font-size: 1rem;
		line-height: 1.2em;
		font-weight: bold;
		color: var(--headerColor);
	}
	#sbs .iws-job {
		display: block;
		font-size: 0.875rem;
		line-height: 1.5em;
		color: #353535;
	}
	#sbs .iws-quote-icon {
		position: absolute;
		bottom: 0rem;
		/* 16px - 32px */
		right: clamp(1rem, 4vw, 2rem);
		height: auto;
		/* 60px - 136px */
		width: clamp(3.75rem, 10vw, 8.5rem);
	}
	#sbs .iws-button-solid {
		margin-top: 2rem;
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#sbs .iws-container {
			flex-flow: row;
			justify-content: space-between;
			gap: 3.25rem;
		}
		#sbs .iws-left {
			font-size: min(1.2vw, 1em);
			flex: none;
		}
		#sbs .iws-right {
			margin: 0;
		}
	}
	/* Dark Mode */
	@media only screen and (min-width: 0rem) {
		body.dark-mode #sbs .iws-left:before,
		body.dark-mode #sbs .iws-left:after {
			background: var(--accent);
		}
		body.dark-mode #sbs .iws-picture2 {
			/* 6px - 12px */
			border: clamp(0.375em, 1.5vw, 0.75em) solid var(--dark);
			background-color: var(--dark);
		}
		body.dark-mode #sbs .iws-topper {
			color: var(--primaryLight);
		}
		body.dark-mode #sbs .iws-title,
		body.dark-mode #sbs .iws-text,
		body.dark-mode #sbs .iws-h3,
		body.dark-mode #sbs .iws-flex-p,
		body.dark-mode #sbs .iws-name {
			color: var(--bodyTextColorWhite);
		}
		body.dark-mode #sbs .iws-flex-group {
			background-color: var(--accent);
		}
		body.dark-mode #sbs .iws-job {
			opacity: 0.8;
			color: var(--bodyTextColorWhite);
		}
		body.dark-mode #sbs .iws-quote-icon {
			opacity: 0.2;
		}
	}
</style>
